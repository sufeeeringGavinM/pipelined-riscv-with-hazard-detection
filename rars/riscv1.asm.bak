# Base pointer is x0 (0x0)
# All results stored sequentially at 4-byte offsets

# 1. Upper Immediates
lui x1, 1               # LUI: x1 = 0x1000
sw x1, 4(x0)            # Result at 0x4
auipc x2, 1             # AUIPC: x2 = PC + 0x1000
sw x2, 8(x0)            # Result at 0x8

# 2. I-Type (ALU Immediate)
addi x3, x0, 100        # x3 = 100
sw x3, 12(x0)
slti x4, x3, 50         # x4 = 0
sw x4, 16(x0)
sltiu x5, x3, 150       # x5 = 1
sw x5, 20(x0)
xori x6, x3, 15         # x6 = 100 ^ 15
sw x6, 24(x0)
ori x7, x3, 120         # x7 = 100 | 120
sw x7, 28(x0)
andi x8, x3, 15         # x8 = 100 & 15
sw x8, 32(x0)
slli x9, x3, 4          # x9 = 100 << 4
sw x9, 36(x0)
srli x11, x3, 2         # x11 = 100 >> 2
sw x11, 40(x0)
srai x12, x3, 2         # x12 = 100 >> 2 (arithmetic)
sw x12, 44(x0)

# 3. R-Type (ALU Register)
addi x13, x0, 20        # src1
addi x14, x0, 5         # src2
add x15, x13, x14       # 25
sw x15, 48(x0)
sub x16, x13, x14       # 15
sw x16, 52(x0)
sll x17, x13, x14       # 20 << 5
sw x17, 56(x0)
slt x18, x13, x14       # 0
sw x18, 60(x0)
sltu x19, x13, x14      # 0
sw x19, 64(x0)
xor x20, x13, x14       # 20 ^ 5
sw x20, 68(x0)
srl x21, x13, x14       # 20 >> 5
sw x21, 72(x0)
sra x22, x13, x14       # 20 >> 5
sw x22, 76(x0)
or x23, x13, x14        # 20 | 5
sw x23, 80(x0)
and x24, x13, x14       # 20 & 5
sw x24, 84(x0)

# 4. Memory (Load/Store)
addi x25, x0, 123       # Small 12-bit imm
sh x25, 88(x0)          # Store half
lh x26, 88(x0)          # Load half
sw x26, 92(x0)          # Result
addi x25, x0, 50        # Small 12-bit imm
sb x25, 96(x0)          # Store byte
lbu x27, 96(x0)         # Load byte unsigned
sw x27, 100(x0)         # Result

# 5. Control Flow
jal x1, jump_label
addi x28, x0, 0         # Skipped
jump_label:
beq x13, x13, branch_label
addi x28, x0, 0         # Skipped
branch_label:
addi x28, x0, 1
sw x28, 104(x0)         # Store '1' if flow worked

# Data Hazard Test: 2 instructions of separation
# Base pointer x0, Memory start 0x0

# --- Hazard 1: RAW (Register-Register) ---
addi x5, x0, 10      # Producer: x5 = 10
addi x1, x0, 0       # Bubble 1 (No dependency)
addi x2, x0, 0       # Bubble 2 (No dependency)
add x6, x5, x5       # Consumer: x6 = x5 + x5 (Uses x5)
sw x6, 128(x0)       # Store result (0x80) -> Expected: 20

# --- Hazard 2: RAW (Load-to-Use) ---
addi x7, x0, 100     # Prep value for memory
sw x7, 136(x0)       # Store 100 at 0x88

lw x8, 136(x0)       # Producer: x8 = 100 (from memory)
addi x1, x0, 0       # Bubble 1
addi x2, x0, 0       # Bubble 2
addi x9, x8, 50      # Consumer: x9 = x8 + 50
sw x9, 132(x0)       # Store result (0x84) -> Expected: 150

